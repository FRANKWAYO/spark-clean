# Copy this file to .env and fill in your SMTP and admin values
# Example values are placeholders — replace with your provider's settings.

# Server port (optional)
PORT=5000

# SMTP settings (required to send emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password

# From address used in outgoing emails (optional)
SMTP_FROM="SparkClean Services <no-reply@example.com>"

# Admin email to receive booking notifications. If omitted, SMTP_USER is used.
ADMIN_EMAIL=owner@example.com

# FRONTEND_ORIGIN (optional) — comma-separated list of allowed origins for CORS
# For local testing you can leave as default (*) or set to http://localhost:5500
#FRONTEND_ORIGIN=http://localhost:5500
# Copy this file to .env and fill in real values. Never commit .env itself.

# Server
PORT=5000

# The domain(s) your frontend is hosted on — comma-separated if you have more than one.
# Use "*" only while developing locally.
FRONTEND_ORIGIN=*

# MongoDB is no longer required for this API.
# All requests are processed via email and not persisted.

# SMTP (for booking/quote/contact email notifications). Works with Gmail
# (use an App Password, not your regular password), SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SparkClean Services <your.email@gmail.com>"

# Where admin notifications (new booking/quote/contact) get sent
ADMIN_EMAIL=admin@sparkclean.example
